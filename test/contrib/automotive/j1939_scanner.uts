def test_two_sas_different_methods():
    import threading
    import time
    sock = TestSocket(CAN)
    _BROADCAST_TIME = 0.05
    _INJECT_OFFSET = 0.02  # inject 20 ms after the broadcast window closes
    def inject_unicast_response():
        time.sleep(_BROADCAST_TIME + _INJECT_OFFSET)
        resp18 = _j1939_can_id(6, 0xEB, J1939_NULL_ADDRESS, 0x18)
        sock.ins.send(bytes(CAN(identifier=resp18, flags="extended",
                                data=b'\x00' * 8)))
    resp17 = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED, J1939_GLOBAL_ADDRESS, 0x17)
    sock.ins.send(bytes(CAN(identifier=resp17, flags="extended",
                            data=b'\x00' * 8)))
    t = threading.Thread(target=inject_unicast_response)
    t.start()
    found = j1939_scan(sock, scan_range=[0x18],
                       methods=["addr_claim", "unicast"],

+ Technique 5 – UDS TesterPresent Probe

= PGN_DIAG_A is 0xDA00, J1939_PF_DIAG_A is 0xDA; PGN_DIAG_B is 0xDB00, J1939_PF_DIAG_B is 0xDB
assert PGN_DIAG_A == 0xDA00
assert J1939_PF_DIAG_A == 0xDA
assert PGN_DIAG_B == 0xDB00
assert J1939_PF_DIAG_B == 0xDB

= uds: sends Functional (broadcast PF|0x01) and Physical (unicast PF) probe frames
def test_uds_probe_frames():
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        # scan_range=[0x20] with 1 src_addr should send 2 probes total
        # 1 broadcast to 0xFF (PF=0xDB) and 1 unicast to 0x20 (PF=0xDA)
        j1939_scan_uds(tx_sock, scan_range=[0x20], sniff_time=0.0,
                       noise_ids=set(), src_addrs=[J1939_NULL_ADDRESS])
        pkts = monitor.sniff(count=2, timeout=0.2)
        assert len(pkts) == 2, "Expected 2 probe frames (Broadcast + Unicast), got {}".format(len(pkts))
        
        # First probe: Broadcast (Functional)
        _, pf, ps, sa = _j1939_decode_can_id(pkts[0].identifier)
        assert pf == J1939_PF_DIAG_B, "First probe should be Functional (PF=0xDB)"
        assert ps == J1939_GLOBAL_ADDRESS, "DA should be Global (0xFF)"
        
        # Second probe: Physical (Unicast)
        _, pf, ps, sa = _j1939_decode_can_id(pkts[1].identifier)
        assert pf == J1939_PF_DIAG_A, "Second probe should be Physical (PF=0xDA)"
        assert ps == 0x20, "DA should be 0x20"
    cleanup_testsockets()

test_uds_probe_frames()


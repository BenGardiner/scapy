= addr_claim: default src_addrs sends one probe per address in J1939_NULL_ADDRESSES
def test_addr_claim_multi_src_addrs():
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        j1939_scan_addr_claim(tx_sock, listen_time=0.0)
        pkts = monitor.sniff(count=len(J1939_NULL_ADDRESSES), timeout=0.5)
        assert len(pkts) == len(J1939_NULL_ADDRESSES), \
            "Expected {} probe frames, got {}".format(
                len(J1939_NULL_ADDRESSES), len(pkts))
        sas = [_j1939_decode_can_id(p.identifier)[3] for p in pkts]
        assert sorted(sas) == sorted(J1939_NULL_ADDRESSES), \
            "Probe SAs should be J1939_NULL_ADDRESSES, got: {}".format(
                [hex(s) for s in sas])
    cleanup_testsockets()


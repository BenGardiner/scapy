                           noise_ids=set(), skip_functional=True)
    assert 0x30 in found, "Expected SA=0x30, got: {}".format(
        [hex(k) for k in found])
    assert isinstance(found[0x30], list)
    assert len(found[0x30]) == 1
    cleanup_testsockets()

test_uds_positive_response()


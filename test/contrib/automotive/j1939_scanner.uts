= uds: both functional and physical responses are captured
def test_uds_both_functional_and_physical():
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        # Inject response for functional broadcast (PF=0xDB, DA=0xFF) from SA=0x55
        resp_f = _j1939_can_id(6, J1939_PF_DIAG_B, J1939_GLOBAL_ADDRESS, 0x55)
        tx_sock.ins.send(bytes(CAN(identifier=resp_f, flags="extended",
                                    data=b'\x02\x7e\x00')))
        # Inject response for physical unicast (PF=0xDA, DA=0x55) from SA=0x55
        resp_p = _j1939_can_id(6, J1939_PF_DIAG_A, J1939_NULL_ADDRESS, 0x55)
        tx_sock.ins.send(bytes(CAN(identifier=resp_p, flags="extended",
                                    data=b'\x02\x7e\x00')))
        found = j1939_scan_uds(tx_sock, scan_range=[0x55], sniff_time=0.1,
                               broadcast_listen_time=0.05,
                               noise_ids=set(), src_addrs=[J1939_NULL_ADDRESS])
        assert 0x55 in found
        # Should have captured both responses
        assert len(found[0x55]) == 2
        # Check PFs
        pfs = {_j1939_decode_can_id(p.identifier)[1] for p in found[0x55]}
        assert pfs == {J1939_PF_DIAG_A, J1939_PF_DIAG_B}
    cleanup_testsockets()

test_uds_both_functional_and_physical()

